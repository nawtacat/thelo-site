rules_version = '2';
service cloud.firestore {
match /databases/{database}/documents {

  // --- Helper Functions ---
  function isSignedIn() {
    return request.auth != null;
  }

  function isOwner(userId) {
    return isSignedIn() && request.auth.uid == userId;
  }

  function isTutor() {
    // Check if the user's email exists in the tutors collection
    return request.auth != null && exists(/databases/$(database)/documents/tutors/$(request.auth.token.email));
  }

  function isMaintenance() {
    return request.auth != null && exists(/databases/$(database)/documents/maintenance/$(request.auth.token.email));
  }

  function isMemberOfGroup(groupId) {
    // Check if the student document exists and has the matching groupId
    return request.auth != null &&
        get(/databases/$(database)/documents/thelo-students/$(request.auth.uid)).data != null &&
        get(/databases/$(database)/documents/thelo-students/$(request.auth.uid)).data.groupId == groupId;
  }

  // Function for student joining a group (updating group's memberIds)
  function isAddingSelfToGroup() {
    let oldData = resource.data;
    let updateData = request.resource.data; // Only contains fields being updated

    // Check 1: Only 'memberIds' field is being updated
    let isOnlyMemberIds = updateData.keys().size() == 1 &&
                          updateData.keys().hasAll(['memberIds']);

    // Check 2: The new 'memberIds' list is the old list + current user
    let oldSet = (!('memberIds' in oldData) || oldData.memberIds == null
                  ? [].toSet()
                  : oldData.memberIds.toSet());
    let newSet = (updateData.memberIds == null
                  ? [].toSet()
                  : updateData.memberIds.toSet());
    let isMemberIdsCorrect = newSet == oldSet.union([request.auth.uid].toSet());

    return isSignedIn() &&
           isOnlyMemberIds &&
           isMemberIdsCorrect;
  }

  // --- Collection Rules ---

  match /groups/{groupId} {
    allow create: if isTutor() &&
                     request.resource.data.ownerId == request.auth.uid &&
                     request.resource.data.ownerEmail == request.auth.token.email;
    allow get: if (isTutor() && resource.data.ownerId == request.auth.uid) || isMemberOfGroup(groupId);
    allow list: if isSignedIn(); // Allow listing for finding join codes
    allow update: if (isTutor() && resource.data.ownerId == request.auth.uid) || isAddingSelfToGroup(); // Tutor owns OR student adds self
    allow delete: if false; // Disallow deletion
  }

  match /bulletin-posts/{postId} {
    allow read: if isMemberOfGroup(resource.data.groupId);
    // Allow create if member OR if it's the specific "welcome" post type by the joining user
    allow create: if (isMemberOfGroup(request.resource.data.groupId) && request.auth.uid == request.resource.data.authorId) ||
                   (request.resource.data.type == 'welcome' && request.auth.uid == request.resource.data.authorId);
    allow update, delete: if false;
  }

  match /thelo-students/{studentId} {
    allow create, update: if isOwner(studentId); // Student manages own profile
    // Allow public read access for the admin dashboard
    allow get, list: if true;
    allow delete: if isOwner(studentId);

    // Subcollections under student
    match /progress/{topicId} {
      allow read, write: if isOwner(studentId); // Student manages own progress
    }
    // This path seems unused based on other rules, keep specific if needed
    match /test_results/{resultId}/{document=**} {
      allow read: if isOwner(studentId);
      allow write: if false;
    }
  }
match /thelo-test-results/{resultId} {
    // Student creates their own test result document
    allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
    
    // --- MODIFICATION 1 ---
    // Allow ANYONE to GET (read) a single result document.
    // This is for the public, shareable result page.
    // We keep the old authenticated rules as well, though if true covers them.
    allow get: if true;
    
    // Tutors can list results (e.g., for their group)
    allow list: if isTutor(); 
    allow update, delete: if false; // Disallow modification after creation

    // --- * Rules for the 'results' Subcollection * ---
    match /results/{questionId} {
      
      // --- MODIFICATION 2 ---
      // Allow ANYONE to READ (get/list) the questions subcollection.
      // This is necessary for the public result page to show the breakdown.
      allow read: if true;

      // Allow CREATE only by the student who owns the parent test result
      allow create: if isSignedIn() &&
                       get(/databases/$(database)/documents/thelo-test-results/$(resultId)).data.uid == request.auth.uid;

      // Deny update and delete from clients
      allow update, delete: if false;
    }
    // --- * End Subcollection Rules * ---
  }

  // --- Tutor Ecosystem Rules ---
  match /tests/{testId} {
    allow read: if isSignedIn();
    allow create: if isSignedIn();
    allow update, delete: if isSignedIn() && resource.data.tutorId == request.auth.uid;
  }

  match /custom_problems/{problemId} {
    allow read: if isSignedIn();
    allow create: if isSignedIn();
    allow update, delete: if isSignedIn() && resource.data.tutorId == request.auth.uid;
  }

// --- Other Collections (Keep as needed) ---
  match /users/{userId} {
    allow read: if true; // Or restrict as needed
    allow write: if isOwner(userId);
  }
  match /reading_sessions/{sessionId} {
    allow read: if true;
    allow create: if isSignedIn();
    allow update: if isSignedIn() && request.auth.uid == resource.data.userId;
    allow delete: if false;
  }
  match /explanation_requests/{requestId} {
    allow read: if true;
    allow create: if isSignedIn();
    allow update: if isSignedIn() && request.auth.uid == resource.data.userId;
    allow delete: if false;
  }
  match /bookmarks/{bookmarkId} {
    allow read, update, delete: if isSignedIn() && bookmarkId.matches(request.auth.uid + '_.*');
    allow create: if isSignedIn() && request.auth.token.firebase.sign_in_provider != 'anonymous' && bookmarkId.matches(request.auth.uid + '_.*') && request.resource.data.userId == request.auth.uid;
  }
  match /analytics_events/{eventId} {
    allow create: if request.auth != null;
    allow read: if true; // Or restrict further
    allow update, delete: if false;
  }
  match /analytics_daily/{dateId} {
    allow read: if true;
    allow write: if true; // Public write for analytics
  }
  match /solution_attempts/{attemptId} {
    allow create: if true; // Public create
    allow get: if true; // Public read
    allow list: if true; // Public list
    allow update, delete: if false;
  }
  match /analytics/{docId} {
    allow create: if request.auth != null;
    allow read: if true; // Or restrict further
    allow update, delete: if false;
  }
  match /thelo-training-digits-demo/{docId} {
    allow create: if request.auth != null;
    allow read, update, delete: if false;
  }
  match /courses/{courseId}/{document=**} {
    allow read: if request.auth != null; // Allow signed-in users to read course content
  }
  match /phone-whiteboard-sessions/{sessionId} {
    allow create: if isSignedIn() &&
                   request.resource.data.lessonId is string &&
                   request.resource.data.desktopSessionActive == true;
    allow read: if isSignedIn();
    allow update: if isSignedIn();
    allow delete: if false;
  }
  match /voiceRooms/{roomId}/{path=**} {
    allow read, write: if request.auth != null; // Adjust as needed for security
  }
  match /rooms/{roomId}/{path=**} {
    allow read, write: if request.auth != null; // Adjust as needed for security
  }
  match /kaffetish_profiles/{userId} {
    allow read, write: if request.auth != null && request.auth.uid == userId;
  }
  match /kaffetish-users/{userId} {
    allow read, update, create: if request.auth != null && request.auth.uid == userId;
  }
  match /applications/{docId} {
    allow read, write: if isMaintenance(); // Only maintenance users
  }
  match /attendance/{docId} {
    allow read, write: if isTutor(); // Only tutors
  }
  match /tutors/{docId} {
    // User creates their own tutor doc using email as ID
    allow create: if request.auth != null && request.auth.token.email == docId;
    // User gets own doc OR any tutor can get any tutor doc (adjust if needed)
    allow get: if (request.auth != null && request.auth.token.email == docId) || isTutor();
    allow list: if isTutor(); // Tutors can list other tutors
    allow update, delete: if false; // Disallow modification
  }
  match /maintenance/{docId} {
    // Maintenance user can get their own doc
    allow get: if request.auth != null && request.auth.token.email == docId;
    allow list, create, update, delete: if false; // Highly restricted
  }
  // This seems redundant given /thelo-students, remove if unused
  match /students/{studentId} {
    allow get: if request.auth != null;
    allow list: if isTutor();
    allow create, update, delete: if false;
  }
  // --- QYACHBET APP RULES ---
  match /qyach_users/{userId} {
    allow read, write: if true;
  }
  
  match /qyach_bets/{betId} {
    allow read, write: if true;
  }
}

}
